{
  "compileOnSave": false,
  "compilerOptions": {
    "sourceMap": true,
    "declaration": false,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "importHelpers": true,
    "target": "ES2022",
    "typeRoots": [
      "./node_modules/@types"
    ],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@rero/shared": [
        "./dist/shared"
      ],
      "@rero/shared/*": [
        "./dist/shared/*"
      ],
      "@app/admin/*": [
        "./projects/admin/src/app/*"
      ],
      "@app/public-search/*": [
        "./projects/public-search/src/app/*"
      ],
      "moment": [
        "./node_modules/moment/min/moment.min.js"
      ],
      "@rero/prime/*": [
        "./node_modules/@rero/ng-core/lib/record/editor/formly/primeng/*"
      ]
    },
    "useDefineForClassFields": false
  },
  "angularCompilerOptions": {
    "strictTemplates": true,
    "strictInjectionParameters": true
  }
}
