{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/spec",
    "types": ["vitest/globals"],
    "paths": {
      "@rero/shared": ["../../projects/shared/src/public-api.ts"],
      "@rero/shared/*": ["../../projects/shared/src/*"],
      "@app/admin/*": ["./src/app/*"],
